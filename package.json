{
  "name": "myblog",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && pagefind --site dist",
    "postbuild": "cp -r dist/pagefind public/pagefind 2>/dev/null || true",
    "preview": "astro preview",
    "deploy": "astro build && pagefind --site dist && bash scripts/deploy.sh"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/tailwind": "^6.0.2",
    "@tailwindcss/typography": "^0.5.16",
    "astro": "^6.4.7",
    "katex": "^0.16.21",
    "pagefind": "^1.5.2",
    "rehype-katex": "^7.0.1",
    "rehype-pretty-code": "^0.14.0",
    "rehype-slug": "^6.0.0",
    "remark-math": "^6.0.0",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "prettier": "^3.5.0",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.7.0"
  }
}
