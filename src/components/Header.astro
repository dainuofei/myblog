---
import { SITE_TITLE } from "../lib/constants";
import ThemeToggle from "./ThemeToggle.astro";
import SearchModal from "./SearchModal.astro";
---

<header
  class="sticky top-0 z-10 border-b border-gray-200 bg-white/80 backdrop-blur dark:border-gray-800 dark:bg-gray-950/80"
>
  <nav class="mx-auto flex max-w-3xl items-center justify-between px-4 py-3">
    <a href="/" class="text-lg font-semibold hover:opacity-80 transition-opacity">
      {SITE_TITLE}
    </a>
    <div class="flex items-center gap-4 text-sm">
      <a href="/" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
        首页
      </a>
      <a href="/tags" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
        标签
      </a>
      <a href="/about" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
        关于
      </a>
      <!-- Search trigger -->
      <button
        id="search-trigger"
        class="flex items-center gap-2 rounded-lg border border-gray-300 px-4 py-1.5 text-sm text-gray-400 hover:text-gray-600 hover:border-gray-400 dark:border-gray-600 dark:text-gray-500 dark:hover:text-gray-300 dark:hover:border-gray-500 transition-colors min-w-[180px]"
        aria-label="搜索文章"
      >
        <svg class="h-4 w-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <span class="flex-1 text-left">搜索文章...</span>
        <kbd class="text-xs opacity-60">⌘K</kbd>
      </button>
      <ThemeToggle />
    </div>
  </nav>
</header>

<SearchModal />
