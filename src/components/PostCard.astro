---
import type { CollectionEntry } from "astro:content";
import { formatDate, readingTime } from "../lib/utils";

interface Props {
  post: CollectionEntry<"posts">;
}

const { post } = Astro.props;
const bodyText = post.body ?? "";
const readTime = readingTime(bodyText);
const description = post.data.description ?? bodyText.slice(0, 200).replace(/\s+/g, " ").trim();
---

<article class="group">
  <a href={`/posts/${post.id}`} class="block">
    <h2
      class="text-xl font-semibold text-gray-900 dark:text-gray-100 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors"
    >
      {post.data.title}
    </h2>
    <div class="mt-1 flex items-center gap-3 text-xs text-gray-500 dark:text-gray-400">
      <time datetime={post.data.date.toISOString()}>
        {formatDate(post.data.date)}
      </time>
      <span>&middot;</span>
      <span>{readTime} 分钟阅读</span>
    </div>
    {
      description && (
        <p class="mt-2 text-sm text-gray-600 dark:text-gray-400 line-clamp-2">
          {description}
        </p>
      )
    }
  </a>
  {
    post.data.tags.length > 0 && (
      <div class="mt-2 flex flex-wrap gap-1.5">
        {post.data.tags.map((tag) => (
          <a
            href={`/tags/${tag}`}
            class="text-xs text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
          >
            #{tag}
          </a>
        ))}
      </div>
    )
  }
</article>
