<!-- Search overlay: iOS 26 Liquid Glass -->
<div
  id="search-overlay"
  class="lg-overlay fixed inset-0 z-50 hidden items-start justify-center pt-[15vh]"
  aria-hidden="true"
>
  <div
    class="lg-panel w-full max-w-xl mx-4"
  >
    <!-- Search input -->
    <div class="flex items-center border-b border-black/10 dark:border-white/10 px-5">
      <svg
        class="h-5 w-5 flex-shrink-0 text-black/40 dark:text-white/50"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
        />
      </svg>
      <input
        id="search-input"
        type="text"
        placeholder="搜索文章..."
        class="w-full border-0 bg-transparent px-3 py-4 text-black/80 placeholder-black/30 focus:outline-none dark:text-white/90 dark:placeholder-white/30"
        autocomplete="off"
      />
      <button
        id="search-close"
        class="flex-shrink-0 rounded-full p-1.5 text-black/30 hover:text-black/60 hover:bg-black/5 dark:text-white/40 dark:hover:text-white/80 dark:hover:bg-white/10 transition-colors"
        aria-label="关闭搜索"
      >
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Results -->
    <div
      id="search-results"
      class="max-h-[50vh] overflow-y-auto px-5 py-3 empty:hidden"
    >
      <p class="py-8 text-center text-sm text-black/40 dark:text-white/40">
        输入关键词开始搜索
      </p>
    </div>

    <!-- Footer -->
    <div
      class="border-t border-black/10 dark:border-white/10 px-5 py-2.5 text-xs text-black/30 dark:text-white/30"
    >
      <kbd class="rounded border border-black/20 dark:border-white/15 px-1.5 py-0.5 text-xs">ESC</kbd> 关闭
    </div>
  </div>
</div>

<style>
  /* Overlay — simple dimmed backdrop, no blur */
  .lg-overlay {
    background: rgba(0, 0, 0, 0.2);
  }

  /* Panel — solid opaque card */
  .lg-panel {
    position: relative;
    background: #ffffff;
    border-radius: 28px;
    border: 1px solid rgba(0, 0, 0, 0.08);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
    overflow: hidden;
  }

  :root.dark .lg-overlay {
    background: rgba(0, 0, 0, 0.4);
  }
  :root.dark .lg-panel {
    background: #1e1e28;
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  }
</style>

<script is:inline>
  let pagefind = null;

  async function loadPagefind() {
    if (pagefind) return pagefind;
    try {
      pagefind = await import("/pagefind/pagefind.js");
      return pagefind;
    } catch {
      console.warn("Pagefind not available (dev mode or not indexed)");
      return null;
    }
  }

  async function doSearch(query) {
    var resultsContainer = document.getElementById("search-results");
    if (!query.trim()) {
      resultsContainer.innerHTML =
        '<p class="py-8 text-center text-sm text-black/40 dark:text-white/40">输入关键词开始搜索</p>';
      return;
    }

    resultsContainer.innerHTML =
      '<p class="py-8 text-center text-sm text-black/40 dark:text-white/40">搜索中...</p>';

    var pf = await loadPagefind();
    if (!pf) {
      resultsContainer.innerHTML =
        '<p class="py-8 text-center text-sm text-black/40 dark:text-white/40">搜索暂不可用（请先执行 pnpm build 构建索引）</p>';
      return;
    }

    var search = await pf.search(query);
    if (!search || search.results.length === 0) {
      resultsContainer.innerHTML =
        '<p class="py-8 text-center text-sm text-black/40 dark:text-white/40">没有找到相关文章</p>';
      return;
    }

    var results = await Promise.all(search.results.slice(0, 10).map(function(r) { return r.data(); }));

    resultsContainer.innerHTML = results
      .map(function(r) {
        return (
          '<a href="' + r.url + '"' +
          ' class="block rounded-xl px-4 py-3 transition-colors hover:bg-black/[0.04] dark:hover:bg-white/[0.06]">' +
          '<div class="text-sm font-medium text-black/80 dark:text-white/90">' +
          (r.meta ? r.meta.title : r.url) +
          '</div>' +
          '<div class="mt-1 text-xs text-black/40 dark:text-white/40 line-clamp-2">' +
          (r.excerpt || "") +
          '</div>' +
          '</a>'
        );
      })
      .join("");
  }

  // ── Modal open/close ──
  var overlay = document.getElementById("search-overlay");
  var input = document.getElementById("search-input");

  function openSearch() {
    overlay.classList.remove("hidden");
    overlay.classList.add("flex");
    overlay.setAttribute("aria-hidden", "false");
    input.value = "";
    input.focus();
    doSearch("");
  }

  function closeSearch() {
    overlay.classList.add("hidden");
    overlay.classList.remove("flex");
    overlay.setAttribute("aria-hidden", "true");
  }

  document.addEventListener("click", function(e) {
    if (e.target.closest("#search-trigger")) {
      e.preventDefault();
      openSearch();
    }
    if (e.target.closest("#search-close") || e.target === overlay) {
      closeSearch();
    }
  });

  document.addEventListener("keydown", function(e) {
    if (e.key === "Escape" && !overlay.classList.contains("hidden")) {
      closeSearch();
    }
    if ((e.metaKey || e.ctrlKey) && e.key === "k") {
      e.preventDefault();
      openSearch();
    }
  });

  var debounceTimer;
  input.addEventListener("input", function() {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(function() { doSearch(input.value); }, 200);
  });
</script>
