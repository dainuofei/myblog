http://106.75.209.37 {
    root * /var/www/blog
    file_server

    header X-Content-Type-Options "nosniff"

    @assets path /_astro/*
    header @assets Cache-Control "public, max-age=31536000, immutable"

    encode gzip

    handle_errors {
        rewrite * /404.html
        file_server
    }
}
